# Local folders
data/
output/
papers/

# Rebuildable local environments
.direnv/
.devenv/
.venv/

# Secrets (commit a sanitized .env.example when useful)
.env
.env.*
!.env.example

# Python build and editor artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Marimo execution state
**/__marimo__/

# R session state
.Rhistory
.RData
.Ruserdata
.Rproj.user/

# renv keeps its project metadata and lockfile under version control. Its
# libraries and staging directories are generated locally.
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/
renv/staging/

# Positron state
.positron/

# Lean build output
.lake/
